{% sw_extends '@Storefront/storefront/layout/footer.html.twig' %}

{#
    H1 Theme Footer - Based on Figma Design
    Design: https://www.figma.com/design/meHFNqt42k9ca1N5KcAfN5/H1-Shopware-Theme?node-id=35-1512

    Dit template voegt H1 styling toe aan de standaard Shopware footer.
    De dynamische content (navigatie kolommen, service menu, etc.) blijft intact.

    IMPORTANT: All texts use snippet system for multilingual support
    IMPORTANT: Shopware JS classes are preserved for collapse functionality

    H1 Design elementen:
    1. Newsletter banner (donker #111111)
    2. USP bar (Free Shipping, Fast delivery, Money-Back Guarantee, Secure Payments)
    3. Footer kolommen (dynamisch uit Shopware admin)
    4. Copyright bar (licht #EEEEEE)
#}

{% block base_footer %}
    <footer class="footer-main h1-footer">
        {# H1 Newsletter Section - Boven de standaard footer content #}
        {% block layout_footer_h1_newsletter %}
            <div class="h1-footer-newsletter">
                <div class="container">
                    <div class="h1-footer-newsletter-content">
                        <div class="h1-footer-newsletter-text">
                            <h3 class="h1-footer-newsletter-title">
                                {{ 'h1Theme.footer.newsletter.title'|trans|sw_sanitize }}
                                <span class="h1-highlight">{{ 'h1Theme.footer.newsletter.highlight'|trans|sw_sanitize }}</span>
                                {{ 'h1Theme.footer.newsletter.titleEnd'|trans|sw_sanitize }}
                            </h3>
                            <p class="h1-footer-newsletter-subtitle">
                                {{ 'h1Theme.footer.newsletter.subtitle'|trans|sw_sanitize }}
                            </p>
                        </div>
                        <form class="h1-footer-newsletter-form">
                            <div class="h1-footer-newsletter-input-wrapper">
                                <input
                                    type="email"
                                    placeholder="{{ 'h1Theme.footer.newsletter.placeholder'|trans|sw_sanitize }}"
                                    class="h1-footer-newsletter-input"
                                    aria-label="{{ 'h1Theme.footer.newsletter.placeholder'|trans|sw_sanitize }}"
                                >
                                <button type="submit" class="h1-footer-newsletter-button">
                                    {{ 'h1Theme.footer.newsletter.button'|trans|sw_sanitize }}
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        {% endblock %}

        {# H1 USP Bar - Icons via sw_include for reusability #}
        {% block layout_footer_h1_usp %}
            <div class="h1-footer-usp">
                <div class="container">
                    <div class="h1-footer-usp-items">
                        <div class="h1-footer-usp-item">
                            <span class="h1-footer-usp-icon">
                                {% sw_include '@H1Theme/storefront/utilities/icon/shipping.html.twig' %}
                            </span>
                            <span class="h1-footer-usp-text">
                                {{ 'h1Theme.footer.usp.shipping'|trans|sw_sanitize }}
                            </span>
                        </div>
                        <div class="h1-footer-usp-item">
                            <span class="h1-footer-usp-icon">
                                {% sw_include '@H1Theme/storefront/utilities/icon/delivery.html.twig' %}
                            </span>
                            <span class="h1-footer-usp-text">
                                {{ 'h1Theme.footer.usp.delivery'|trans|sw_sanitize }}
                            </span>
                        </div>
                        <div class="h1-footer-usp-item">
                            <span class="h1-footer-usp-icon">
                                {% sw_include '@H1Theme/storefront/utilities/icon/guarantee.html.twig' %}
                            </span>
                            <span class="h1-footer-usp-text">
                                {{ 'h1Theme.footer.usp.guarantee'|trans|sw_sanitize }}
                            </span>
                        </div>
                        <div class="h1-footer-usp-item">
                            <span class="h1-footer-usp-icon">
                                {% sw_include '@H1Theme/storefront/utilities/icon/secure.html.twig' %}
                            </span>
                            <span class="h1-footer-usp-text">
                                {{ 'h1Theme.footer.usp.secure'|trans|sw_sanitize }}
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        {% endblock %}

        {# Dynamische Shopware footer content met H1 styling #}
        {# IMPORTANT: sw_include preserves all Shopware JS functionality (collapse, etc.) #}
        {% block base_footer_inner %}
            <div class="h1-footer-columns">
                {% sw_include '@Storefront/storefront/layout/footer/footer.html.twig' %}
            </div>
        {% endblock %}

        {# H1 Copyright Bar - Payment icons dynamisch uit Shopware #}
        {% block layout_footer_h1_copyright %}
            <div class="h1-footer-copyright">
                <div class="container">
                    <div class="h1-footer-copyright-content">
                        <p class="h1-footer-copyright-text">
                            {{ 'h1Theme.footer.copyright.text'|trans|sw_sanitize }}
                        </p>
                        <div class="h1-footer-payment-icons">
                            {# Dynamic payment icons from Shopware configuration #}
                            {% sw_include '@Storefront/storefront/layout/footer/footer-payment-logos.html.twig' %}
                        </div>
                    </div>
                </div>
            </div>
        {% endblock %}
    </footer>
{% endblock %}
